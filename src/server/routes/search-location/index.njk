{% extends 'layouts/page.njk' %}
{% from "govuk/components/button/macro.njk" import govukButton %}

{% block content %}
<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds-from-desktop">

    {% if errors.list %}
      <div class="govuk-error-summary" data-module="govuk-error-summary">
        <div role="alert">
          <h2 class="govuk-error-summary__title">There is a problem</h2>
          <div class="govuk-error-summary__body">
            <ul class="govuk-list govuk-error-summary__list">
              <li><a href="#search-input">{{ errorMessage.message.text }}</a></li>
            </ul>
          </div>
        </div>
      </div>
    {% endif %}

    <form action="/multiplelocations" method="post">

      <div class="govuk-form-group">
        <h1 class="govuk-label-wrapper">
          <label class="govuk-heading-l govuk-!-margin-bottom-4" for="search-input">
            {{ heading }}
          </label>
        </h1>
        <p id="search-input-hint" class="govuk-body govuk-hint">
          {{ hint }}
        </p>
      </div>

      {% if errorMessage.message %}
        <div class="govuk-form-group govuk-form-group--error">
          <label class="govuk-label" for="search-input">{{ inputLabel }}</label>
          <p id="search-input-error" class="govuk-error-message">
            <span class="govuk-visually-hidden">Error:</span> {{ errorMessage.message.text }}
          </p>
          <input class="govuk-input govuk-input--error"
                 id="search-input"
                 name="fullSearchQuery"
                 type="text"
                 aria-describedby="search-input-hint search-input-error"
                 value="{{ fullSearchQuery.value }}">
        </div>
      {% else %}
        <div class="govuk-form-group">
          <label class="govuk-label govuk-!-font-weight-bold" for="search-input">{{ inputLabel }}</label>
          <input class="govuk-input"
                 id="search-input"
                 name="fullSearchQuery"
                 type="text"
                 aria-describedby="search-input-hint"
                 value="{{ fullSearchQuery.value }}">
        </div>
      {% endif %}

      {{ govukButton({ text: buttonText }) }}

    </form>
  </div>
</div>
{% endblock %}

