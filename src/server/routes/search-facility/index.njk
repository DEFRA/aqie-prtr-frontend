{% extends 'layouts/page.njk' %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{% block content %}
<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">

    {% if error %}
      {{ govukErrorSummary({
        titleText: errorTitle,
        errorList: [{ text: error, href: "#searchType" }]
      }) }}
    {% endif %}

    {{ appHeading({ text: heading }) }}

    {% set radioError = { text: error } if error else null %}

    <form method="post" action="/search-facility" novalidate>
      {{ govukRadios({
        name: "searchType",
        fieldset: { legend: { text: hint, classes: "govuk-fieldset__legend--s" } },
        errorMessage: radioError,
        items: items
      }) }}
      {{ govukButton({ text: buttonText }) }}
    </form>
  </div>
</div>
{% endblock %}
