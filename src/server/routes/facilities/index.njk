{% extends 'layouts/page.njk' %}
{% from "govuk/components/pagination/macro.njk" import govukPagination %}

{% block content %}
  {{ appHeading({ text: heading }) }}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">

      <p class="govuk-body" data-testid="facilities-summary">
        {{ summaryTemplate
            | replace('{from}', summary.from)
            | replace('{to}', summary.to)
            | replace('{total}', summary.total) }}
      </p>

      <table class="govuk-table" data-testid="facilities-table">
        <thead class="govuk-table__head">
          <tr class="govuk-table__row">
            <th scope="col" class="govuk-table__header">{{ table.facility }}</th>
            <th scope="col" class="govuk-table__header">{{ table.activity }}</th>
            <th scope="col" class="govuk-table__header">{{ table.reporting }}</th>
            <th scope="col" class="govuk-table__header">{{ table.action }}</th>
          </tr>
        </thead>
        <tbody class="govuk-table__body">
          {% for facility in facilities %}
            <tr class="govuk-table__row">
              <td class="govuk-table__cell">
                <span class="govuk-!-font-weight-bold">{{ facility.name }}</span><br>
                <span class="govuk-hint govuk-!-margin-bottom-0">
                  {{ table.milesAway | replace('{distance}', facility.distanceMiles) }}
                </span>
              </td>
              <td class="govuk-table__cell">{{ facility.activity }}</td>
              <td class="govuk-table__cell">
                {% for line in facility.reporting %}{{ line }}<br>{% endfor %}
              </td>
              <td class="govuk-table__cell">
                <a class="govuk-link" href="/facility/{{ facility.id }}">{{ table.view }}</a>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>

      {% if pagination %}
        {{ govukPagination(pagination) }}
      {% endif %}

    </div>
  </div>
{% endblock %}
